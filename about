  <script>
    // ===== WECHAT MODAL FUNCTIONALITY =====
    function openWeChatModal() {
      const modal = document.getElementById('wechatModal');
      const qrImg = document.getElementById('wechatQR');
      
      const wechatID = 'swindonbooks_hk';
      qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=${encodeURIComponent('https://weixin.qq.com/r/' + wechatID)}`;
      
      modal.classList.add('active');
    }

    function closeWeChatModal() {
      const modal = document.getElementById('wechatModal');
      modal.classList.remove('active');
    }

    window.onclick = function(event) {
      const modal = document.getElementById('wechatModal');
      if (event.target === modal) {
        modal.classList.remove('active');
      }
    }
  </script>
